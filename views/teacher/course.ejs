<%- include('../partial/header', { title: course.name }) %>
<header class="topbar">
  <a href="/teacher/dashboard" class="topbar-back">← 课程列表</a>
  <span class="topbar-title"><%= course.name %></span>
  <span class="topbar-user">👤 <%= session.teacherName %></span>
</header>

<main class="main-container">
  <!-- Course Info Bar -->
  <div class="info-bar">
    <div class="info-item">
      <span class="info-label">状态</span>
      <span class="badge <%= course.status === 'active' ? 'badge-active' : 'badge-ended' %>">
        <%= course.status === 'active' ? '进行中' : '已结束' %>
      </span>
    </div>
    <div class="info-item">
      <span class="info-label">签到口令</span>
      <span class="info-password" id="passwordDisplay"><%= course.password %></span>
      <% if (course.status === 'active') { %>
        <button class="btn btn-sm" onclick="regeneratePassword()" title="重新生成口令">🔄</button>
      <% } %>
    </div>
    <div class="info-item">
      <span class="info-label">座位范围</span>
      <span><%= course.max_row %>行 × <%= course.max_col %>列</span>
    </div>
    <div class="info-actions">
      <% if (course.status === 'active') { %>
        <button class="btn" onclick="showQR()" title="展示签到二维码">📱 二维码</button>
        <button class="btn btn-warn" onclick="endCourse()">⏹ 结束签到</button>
        <button class="btn btn-sm" onclick="copyCheckinUrl()">📋 复制签到地址</button>
      <% } else { %>
        <button class="btn btn-primary" onclick="startCourse()">▶ 重新开始</button>
      <% } %>
      <a href="/teacher/course/<%= course.id %>/settings" class="btn btn-sm">⚙️ 设置</a>
      <button class="btn btn-sm btn-warn" onclick="resetAllCheckins()" title="清除所有签到记录">↺ 重置签到</button>
      <button class="btn btn-sm btn-danger" onclick="deleteCourse()" title="删除课程">🗑 删除</button>
    </div>
  </div>

  <!-- Stats -->
  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-number" id="checkedCount"><%= checkins.length %></div>
      <div class="stat-label">已签到</div>
    </div>
    <% if (totalStudents > 0) { %>
    <div class="stat-card">
      <div class="stat-number"><%= totalStudents %></div>
      <div class="stat-label">应到人数</div>
    </div>
    <div class="stat-card">
      <div class="stat-number" id="absentCount"><%= totalStudents > 0 ? totalStudents - checkins.length : 0 %></div>
      <div class="stat-label">未签到</div>
    </div>
    <div class="stat-card">
      <div class="stat-number" id="rateCount"><%= totalStudents > 0 ? Math.round(checkins.length / totalStudents * 100) : 0 %>%</div>
      <div class="stat-label">签到率</div>
    </div>
    <% } %>
    <div class="stat-card stat-warn" id="conflictCard" style="<%= conflictSeats.length > 0 ? '' : 'display:none' %>">
      <div class="stat-number" id="conflictCount"><%= conflictSeats.length %></div>
      <div class="stat-label">⚠ 座位冲突</div>
    </div>
  </div>

  <!-- View toggle -->
  <div class="view-toggle">
    <button class="btn active" id="btnGridView" onclick="switchView('grid')">🗺 网格视图</button>
    <button class="btn btn-pick" id="btnPick" onclick="togglePick()">🎲 随机点名</button>
    <button class="btn" id="btnListView" onclick="switchView('list')">📋 列表视图</button>
    <a href="/teacher/course/<%= course.id %>/export" class="btn btn-sm">📥 导出CSV</a>
  </div>

  <!-- ===== GRID VIEW ===== -->
  <div id="gridView" class="card">
    <div class="grid-legend">
      <span class="legend-item"><span class="seat seat-taken"></span> 已签到</span>
      <span class="legend-item"><span class="seat seat-conflict"></span> 冲突</span>
      <span class="legend-item"><span class="seat seat-empty"></span> 空位</span>
      <span class="legend-item"><span class="seat" style="background:#fde68a;border-color:#f59e0b;"></span> 点名中</span>
      <span class="legend-item"><span class="seat" style="background:#fef3c7;border:3px solid #f59e0b;"></span> 已点中</span>
    </div>
    <div class="seat-grid-wrapper">
      <table class="seat-grid" id="seatGrid">
        <thead>
          <tr>
            <th class="corner"></th>
            <% for (let c = 1; c <= course.max_col; c++) { %>
              <th>列<%= c %></th>
            <% } %>
          </tr>
        </thead>
        <tbody>
          <% for (let r = course.max_row; r >= 1; r--) { %>
          <tr>
            <th>行<%= r %></th>
            <% for (let c = 1; c <= course.max_col; c++) {
              const seatCheckins = checkins.filter(ci => ci.row === r && ci.col === c);
              let cls = 'seat-empty';
              let title = `${r}行${c}列 - 空位`;
              let content = '';
              if (seatCheckins.length >= 2) {
                cls = 'seat-conflict';
                title = `${r}行${c}列 - 冲突! ${seatCheckins.map(s => s.name).join(', ')}`;
                content = seatCheckins.map(s => s.name).join('/');
              } else if (seatCheckins.length === 1) {
                cls = 'seat-taken';
                title = `${r}行${c}列 - ${seatCheckins[0].student_id} ${seatCheckins[0].name}`;
                content = seatCheckins[0].name;
              }
            %>
              <td class="<%= cls %>" title="<%= title %>" data-row="<%= r %>" data-col="<%= c %>">
                <%= content %>
              </td>
            <% } %>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <% if (conflictSeats.length > 0) { %>
      <div class="conflict-alert">
        ⚠️ 检测到 <strong><%= conflictSeats.length %></strong> 个座位冲突：
        <% conflictSeats.forEach(cs => { %>
          <%= cs.row %>行<%= cs.col %>列
        <% }) %>
      </div>
    <% } %>
  </div>

  <!-- QR Code Modal -->
  <div id="qrModal" class="qr-overlay" style="display:none;" onclick="hideQR(event)">
    <div class="qr-modal" onclick="event.stopPropagation()">
      <h2>📱 扫码签到</h2>
      <p style="color:var(--color-text-secondary);margin-bottom:12px;">
        课程：<%= course.name %><br>口令：<strong id="qrPassword"><%= course.password %></strong>
      </p>
      <img id="qrImage" src="" alt="签到二维码" style="display:block;max-width:280px;margin:0 auto;">
      <p style="font-size:13px;color:var(--color-text-secondary);margin-top:12px;">
        学生扫描二维码可直接进入签到页面，无需手动输入口令
      </p>
      <button class="btn" onclick="document.getElementById('qrModal').style.display='none'" style="margin-top:8px;">关闭</button>
    </div>
  </div>

  <!-- ===== LIST VIEW ===== -->
  <div id="listView" class="card" style="display:none;">
    <table class="checkin-table" id="checkinTable">
      <thead>
        <tr>
          <th>#</th>
          <th>学号</th>
          <th>姓名</th>
          <th>行</th>
          <th>列</th>
          <th>签到时间</th>
          <th>操作</th>
        </tr>
      </thead>
      <tbody id="checkinTbody">
        <% checkins.forEach((c, i) => {
          const isConflict = conflictSeats.some(cs => cs.row === c.row && cs.col === c.col);
        %>
        <tr class="<%= isConflict ? 'row-conflict' : '' %>" id="row-<%= c.id %>">
          <td><%= i + 1 %></td>
          <td><%= c.student_id %></td>
          <td><%= c.name %></td>
          <td><%= c.row %></td>
          <td><%= c.col %></td>
          <td><%= c.created_at %></td>
          <td>
            <button class="btn btn-sm btn-danger" onclick="resetCheckin(<%= c.id %>, '<%= c.student_id %>', '<%= c.name %>', <%= c.row %>, <%= c.col %>)">
              重置
            </button>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% if (checkins.length === 0) { %>
      <div class="empty-state"><p>还没有学生签到</p></div>
    <% } %>
  </div>

  <!-- Random Pick Overlay -->
  <div id="pickOverlay" class="pick-overlay" style="display:none;" >
    <div class="pick-card" id="pickCard">
      <div class="pick-avatar" id="pickAvatar">🎲</div>
      <div class="pick-name" id="pickName"></div>
      <div class="pick-info" id="pickInfo"></div>
      <div class="pick-actions" id="pickActions">
        <button class="btn btn-primary" onclick="confirmPick()">✅ 就是TA</button>
        <button class="btn" onclick="restartPick()">🔄 重新点名</button>
        <button class="btn btn-sm" onclick="closePick()">✖ 关闭</button>
      </div>
    </div>
  </div>

  <!-- Manual checkin from absent list -->
  <% if (course.status === 'active') { %>
    <button class="btn" onclick="showManualForm()" style="margin-top:16px">➕ 从未签到列表添加</button>
    <div id="manualForm" class="card" style="display:none; margin-top:16px;">
      <h3>选择未签到学生</h3>
      <div id="absentListContainer">
        <p class="loading-text">加载中...</p>
      </div>
      <div id="selectedStudent" style="display:none; margin-top:16px; padding:12px; background:#f0fdf4; border-radius:8px;">
        <strong>已选择：</strong><span id="selectedInfo"></span>
        <button class="btn btn-sm" onclick="clearSelection()">取消</button>
        <form onsubmit="return manualCheckin(event)" style="margin-top:12px;">
          <div class="form-row">
            <div class="form-group">
              <label>行</label>
              <select id="manualRow" required>
                <option value="">选择行</option>
                <% for (let r = 1; r <= course.max_row; r++) { %>
                  <option value="<%= r %>">第<%= r %>行</option>
                <% } %>
              </select>
            </div>
            <div class="form-group">
              <label>列</label>
              <select id="manualCol" required>
                <option value="">选择列</option>
                <% for (let c = 1; c <= course.max_col; c++) { %>
                  <option value="<%= c %>">第<%= c %>列</option>
                <% } %>
              </select>
            </div>
          </div>
          <button type="submit" class="btn btn-primary">确认签到</button>
          <button type="button" class="btn" onclick="document.getElementById('manualForm').style.display='none'">关闭</button>
        </form>
      </div>
    </div>
  <% } %>
</main>

<script>
// ── Server-side data for JS modules ──
window.COURSE_ID = <%= course.id %>;
window.COURSE_NAME = <%- JSON.stringify(course.name).replace(/<\//g, '<\\/') %>;
window.COURSE_MAX_ROW = <%= course.max_row %>;
window.COURSE_MAX_COL = <%= course.max_col %>;
window.COURSE_TOTAL_STUDENTS = <%= totalStudents || 0 %>;
</script>
<script src="/js/course/grid.js"></script>
<script src="/js/course/picker.js"></script>
<script src="/js/course/actions.js"></script>
<script src="/js/course/checkin.js"></script>
<script src="/js/course/manual.js"></script>
<script src="/js/course/sse.js"></script>
<script src="/js/course/main.js"></script>
<%- include('../partial/footer') %>
